<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.kamotomo.pos.StockMonitorController" style="-fx-background-color: transparent;">

    <VBox spacing="5">
        <Label text="STOCK MONITORING &amp; PURCHASING" style="-fx-text-fill: -kmtm-text; -fx-font-family: 'Bebas Neue', sans-serif; -fx-font-size: 28px; -fx-letter-spacing: 1px;"/>
        <Label text="Track inventory, draft supplier orders, and receive deliveries" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 11px;"/>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="15">

        <HBox spacing="10">
            <ToggleButton fx:id="btnFilterAll" text="All Items" styleClass="filter-toggle" selected="true"/>
            <ToggleButton fx:id="btnFilterCritical" text="🔴 Critical" styleClass="filter-toggle"/>
            <ToggleButton fx:id="btnFilterLow" text="🟡 Low" styleClass="filter-toggle"/>
            <ToggleButton fx:id="btnFilterOk" text="🟢 Sufficient" styleClass="filter-toggle"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="btnPendingOrders" text="📦 View Pending Orders" onAction="#onViewPendingOrders" style="-fx-background-color: transparent; -fx-text-fill: -kmtm-text-dim; -fx-border-color: -kmtm-border; -fx-border-radius: 4; -fx-padding: 8 15; -fx-cursor: hand; -fx-font-family: 'IBM Plex Mono'; -fx-font-weight: bold;"/>
        <Button fx:id="btnDraftOrder" text="📝 Draft Supplier Order" onAction="#onDraftSupplierOrder" style="-fx-background-color: -kmtm-surface2; -fx-text-fill: -kmtm-text; -fx-border-color: -kmtm-border; -fx-border-radius: 4; -fx-padding: 8 15; -fx-cursor: hand; -fx-font-family: 'IBM Plex Mono'; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="100" />
            <TableColumn fx:id="colName" text="NAME" prefWidth="280" />
            <TableColumn fx:id="colCategory" text="CATEGORY" prefWidth="150" />
            <TableColumn fx:id="colStockLevel" text="STOCK LEVEL" prefWidth="200" />
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="100" />
            <TableColumn fx:id="colAction" text="ACTION" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>