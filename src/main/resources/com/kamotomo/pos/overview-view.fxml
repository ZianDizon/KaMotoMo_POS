<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="20.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.kamotomo.pos.OverviewController"
      style="-fx-background-color: transparent;" fx:id="overviewRoot">

    <HBox spacing="15">
        <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: #f5620f -kmtm-border -kmtm-border -kmtm-border; -fx-border-width: 2 1 1 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="TODAY'S SALES" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px; -fx-letter-spacing: 1px;"/>
            <Label fx:id="lblTodaySales" text="₱0.00" style="-fx-text-fill: -kmtm-primary; -fx-font-family: 'Bebas Neue', sans-serif; -fx-font-size: 32px;"/>
            <Label fx:id="lblTodayTxnCount" text="0 transaction(s)" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px;"/>
        </VBox>

        <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: #3adf8a -kmtm-border -kmtm-border -kmtm-border; -fx-border-width: 2 1 1 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="TOTAL REVENUE" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px; -fx-letter-spacing: 1px;"/>
            <Label fx:id="lblTotalRevenue" text="₱0.00" style="-fx-text-fill: #3adf8a; -fx-font-family: 'Bebas Neue', sans-serif; -fx-font-size: 32px;"/>
            <Label text="All-time" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px;"/>
        </VBox>

        <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: #eab308 -kmtm-border -kmtm-border -kmtm-border; -fx-border-width: 2 1 1 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="ACTIVE PRODUCTS" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px; -fx-letter-spacing: 1px;"/>
            <Label fx:id="lblActiveProducts" text="0" style="-fx-text-fill: #eab308; -fx-font-family: 'Bebas Neue', sans-serif; -fx-font-size: 32px;"/>
            <Label text="Currently monitored" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px;"/>
        </VBox>

        <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: #f03d3d -kmtm-border -kmtm-border -kmtm-border; -fx-border-width: 2 1 1 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="LOW STOCK ALERTS" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px; -fx-letter-spacing: 1px;"/>
            <Label fx:id="lblLowStock" text="0" style="-fx-text-fill: #f03d3d; -fx-font-family: 'Bebas Neue', sans-serif; -fx-font-size: 32px;"/>
            <Label text="Items below threshold" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 10px;"/>
        </VBox>
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS" prefHeight="350">
        <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: -kmtm-border; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" HBox.hgrow="ALWAYS">
            <Label text="MONTHLY SALES - CURRENT YEAR" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>
            <BarChart fx:id="salesChart" animated="true" legendVisible="false" VBox.vgrow="ALWAYS">
                <xAxis><CategoryAxis fx:id="xAxis" animated="false" /></xAxis>
                <yAxis><NumberAxis fx:id="yAxis" animated="false" /></yAxis>
            </BarChart>
        </VBox>

        <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: -kmtm-border; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" minWidth="320">
            <Label text="⚠ CRITICAL STOCK" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 11px; -fx-letter-spacing: 1px;"/>
            <ListView fx:id="criticalStockList" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 10 0 0 0; -fx-border-color: transparent;"/>
        </VBox>
    </HBox>

    <VBox style="-fx-background-color: -kmtm-surface; -fx-border-color: -kmtm-border; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15;" prefHeight="250">
        <Label text="RECENT TRANSACTIONS" style="-fx-text-fill: -kmtm-text-dim; -fx-font-family: 'IBM Plex Mono'; -fx-font-size: 11px; -fx-letter-spacing: 1px; -fx-padding: 0 0 10 0;"/>

        <TableView fx:id="recentTxnTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTxnId" text="TXN ID" prefWidth="150" />
                <TableColumn fx:id="colDate" text="DATE" prefWidth="200" />
                <TableColumn fx:id="colItems" text="ITEMS" prefWidth="120" />
                <TableColumn fx:id="colTotal" text="TOTAL" prefWidth="120" />
                <TableColumn fx:id="colPayment" text="PAYMENT" prefWidth="120" />
                <TableColumn fx:id="colCashier" text="CASHIER" prefWidth="150" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>